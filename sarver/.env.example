MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=gamedb

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SERVICE_URL=http://127.0.0.1:3000
NAVER_CALLBACK_URL=http://127.0.0.1:3000/auth/naver/callback

# JWT session token (Unity에 전달되는 토큰)
SESSION_JWT_SECRET=change-me-to-a-long-random-secret
SESSION_JWT_TTL_SECONDS=2592000

# DB에 저장되는 네이버 토큰 암호화 키 (미설정 시 SESSION_JWT_SECRET 사용)
TOKEN_ENCRYPTION_KEY=

# OAuth 성공 후 Unity HttpListener 콜백 URL
UNITY_CALLBACK_URL=http://127.0.0.1:7777/naver-login/

# 브라우저 로그인 세션을 Unity가 가져올 때 사용하는 로컬 브리지 파일
# 기본: %USERPROFILE%/.naver-login-project/local-session.json

# 개발용 전체 초기화: npm run dev:reset
# Unity 메뉴: Naver Login > Dev Reset Tools
# 개발용 유저만 초기화 (MD 호환): POST /debug/reset 또는 POST /auth/dev/reset
#   Body: { "sessionToken": "..." }  — Naver grant_type=delete + 해당 users 행 DELETE
